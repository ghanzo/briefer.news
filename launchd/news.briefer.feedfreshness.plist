<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>news.briefer.feedfreshness</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/maxgoshay/code/briefernewsapp/scripts/feed_freshness.py</string>
  </array>

  <!-- Confirmed low-cadence gov sources (triage 2026-05-31): genuinely quiet,
       not broken. Reported in the dated log but never alerted on. -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>BRIEFER_FRESHNESS_IGNORE</key>
    <string>ARPA-E — News &amp; Insights, CFPB — Newsroom, Court of International Trade, Australia DFAT — Departmental Media Releases, Joint Chiefs of Staff, State Dept — Treaties (TIAS)</string>
  </dict>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/maxgoshay/code/briefernewsapp/logs/feed-freshness-launchagent.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/maxgoshay/code/briefernewsapp/logs/feed-freshness-launchagent.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
