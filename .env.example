# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=briefer
POSTGRES_USER=briefer
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@briefer.news
PGADMIN_PASSWORD=change_me_to_a_strong_password

# ── Pipeline ───────────────────────────────────────────────────────────────────
# Time to run the daily briefing (24h format, server local time)
SCHEDULE_TIME=06:00

# How many top articles to include in each daily briefing
TOP_ARTICLES_COUNT=5

# Article text minimum length to consider valid (chars)
MIN_ARTICLE_LENGTH=300
